# Auto-generated corpus and crash artifacts — do not commit.
# Hand-crafted seeds live in fuzz/seeds/ and are tracked.
corpus/
artifacts/

# ipset_ops and ipset_builder take structured binary input; no hand-crafted seeds.
seeds/ipset_ops/
seeds/ipset_builder/

# libFuzzer saves coverage-increasing inputs as 40-char hex filenames.
# Ignore those auto-generated entries; only the named hand-crafted seeds are committed.
seeds/*/*
!seeds/parse_range/full_v4
!seeds/parse_range/single_ip_v4
!seeds/parse_range/private_v4
!seeds/parse_range/empty_v6_attempt
!seeds/parse_range/full_v6
!seeds/parse_range/doc_v6
!seeds/parse_prefix/slash0_v4
!seeds/parse_prefix/slash32_v4
!seeds/parse_prefix/rfc1918_v4
!seeds/parse_prefix/host_bits_v4
!seeds/parse_prefix/slash0_v6
!seeds/parse_prefix/doc_v6
!seeds/parse_prefix/slash128_v6
